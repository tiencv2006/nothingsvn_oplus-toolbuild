#!/sbin/sh
set -e
ZIP=$3
OUTFD=/proc/self/fd/$2;
ui_print() { echo -e "ui_print $1\nui_print" > $OUTFD; }

if [ -d /tmp/maianh ];then rm -r /tmp/maianh ; fi
mkdir -p /tmp/maianh/bin
unzip "$ZIP" META-INF/bin/* -d /tmp/maianh
mv /tmp/maianh/META-INF/bin/* /tmp/maianh/bin
unzip "$ZIP" META-INF/Data/Structure -d /tmp/maianh
unzip "$ZIP" META-INF/Data/DeviceCode -d /tmp/maianh
unzip "$ZIP" META-INF/Data/DeviceName -d /tmp/maianh
unzip "$ZIP" META-INF/Data/AndroidVer -d /tmp/maianh
unzip "$ZIP" META-INF/Data/Region -d /tmp/maianh
unzip "$ZIP" META-INF/Data/RomBased -d /tmp/maianh
unzip "$ZIP" META-INF/Data/Version -d /tmp/maianh
unzip "$ZIP" META-INF/Data/Types -d /tmp/maianh
unzip "$ZIP" META-INF/Data/Chip -d /tmp/maianh
chmod -R 0777 /tmp/maianh
structure=$(cat '/tmp/maianh/META-INF/Data/Structure')
model=$(cat '/tmp/maianh/META-INF/Data/DeviceModel')
name=$(cat '/tmp/maianh/META-INF/Data/DeviceName')
android=$(cat '/tmp/maianh/META-INF/Data/AndroidVer')
region=$(cat '/tmp/maianh/META-INF/Data/Region')
based=$(cat '/tmp/maianh/META-INF/Data/RomBased')
version=$(cat '/tmp/maianh/META-INF/Data/Version')
Chip=$(cat '/tmp/maianh/META-INF/Data/Chip')
partitionPath="/dev/block/bootdevice/by-name"
systemPath="/dev/block/mapper"

export PATH=/tmp/maianh/bin:$PATH

ui_print "> Check infomation... "

if [ "$Chip" != "Snapdragon" ]; then
  echo "Device is mediatek chip and is not supported to be install from recovery!"
  exit 1
fi

ui_print "------------------------------------------------"
ui_print "Device Name: $name"
ui_print "Model: $model"
ui_print "Android: $android"
ui_print "Based: $based"
ui_print "Region: $region"
ui_print "Version: $version"
ui_print "------------------------------------------------"
ui_print " "

ui_print "> Starting Installing... "
ui_print " "
ui_print "----- Flashing firmware -----"
ui_print " "

for firmwareFile in $(7zz l "$ZIP" | grep firmware-update | grep -o "/.*" ); do
	partition=${imageFile##*/}
	partition=${partition%%.*}
	if [ "$structure" == "VAB" ] ;then
	    ui_print "> Flashing ${partition}_a"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/${partition}_a" 
		ui_print "> Flashing ${partition}_b"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/${partition}_b" 
	else
	    ui_print "> Flashing ${partition}"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/${partition}"
	fi
done

for systemFile in $(7zz l "$ZIP" | grep system | grep -o "/.*" ); do
	partition=${imageFile##*/}
	partition=${partition%%.*}
	if [ "$structure" == "VAB" ] ;then
	    ui_print "> Flashing ${partition}_a"
		unzip -p "$ZIP" "images${imageFile}" > "${systemPath}/${partition}_a" 
	else
	    ui_print "> Flashing ${partition}"
		unzip -p "$ZIP" "images${imageFile}" > "${systemPath}/${partition}"
	fi
done

for imageFile in $(7zz l "$ZIP" | grep images | grep -o "/.*" ); do
	partition=${imageFile##*/}
	partition=${partition%%.*}
	if [ "$partition" == "vendorboot_edt" ] ;then
	    ui_print "> Flashing vendor_boot_a"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/vendor_boot_a" 
		ui_print "> Flashing vendor_boot_b"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/vendor_boot_b" 
	elif [ "$partition" == "vendorboot_stk" ] ;then
	    ui_print "> Skipping flash vendorboot_stk"
	elif [ "$structure" == "VAB" ] ;then
	    ui_print "> Flashing ${partition}_a"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/${partition}_a" 
		ui_print "> Flashing ${partition}_b"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/${partition}_b" 
	else
	    ui_print "> Flashing ${partition}"
		unzip -p "$ZIP" "images${imageFile}" > "${partitionPath}/${partition}"
	fi
done


rm -rf /data/dalvik-cache/arm/*
rm -rf /data/dalvik-cache/arm64/*

ui_print "----- Install Success -----"
ui_print " "
ui_print "Try format data if not boot"

exit 0
